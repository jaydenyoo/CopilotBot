# Required
TELEGRAM_BOT_TOKEN=your-bot-token-here
TELEGRAM_USER_ID=your-numeric-user-id

# Optional: repo working directory (defaults to current dir)
# REPO_DIR=/path/to/your/repo

# Optional: extra PATH entries for non-standard tool locations (colon-separated)
# EXTRA_PATH=/path/to/gh/bin:/path/to/other/bin
